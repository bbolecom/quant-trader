# Streamlit Secrets 示例（本地复制为 .streamlit/secrets.toml，Cloud 在控制台填写）

# ---------------------------------------------------------------------------
# 行情数据源（推荐 Polygon 或 Alpaca，Yahoo 为免费备用）
# ---------------------------------------------------------------------------
[data]
# provider 可选: polygon | alpaca | yahoo
provider = "polygon"

# Polygon.io — 交易所级美股数据（https://polygon.io 注册 API Key）
polygon_api_key = "your-polygon-api-key"

# Alpaca Markets — 券商级行情（https://alpaca.markets 免费开户）
# alpaca_api_key = "your-alpaca-key"
# alpaca_api_secret = "your-alpaca-secret"
# alpaca_data_url = "https://data.alpaca.markets"

# 也可使用环境变量（适合本地脚本 / CI）：
#   DATA_PROVIDER=polygon
#   POLYGON_API_KEY=xxx
#   ALPACA_API_KEY=xxx
#   ALPACA_API_SECRET=xxx
